---

<section id="landing-minimal" class="landing-minimal">
  <svg class="background-geo" width="100%" height="100%" viewBox="0 0 1440 480" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="220" y="90" width="320" height="320" rx="40" fill="none" stroke="#90a7a5" stroke-width="1.2" opacity="0.07"/>
    <rect x="650" y="70" width="280" height="280" rx="40" fill="none" stroke="#90a7a5" stroke-width="1.2" opacity="0.08"/>
    <rect x="1020" y="120" width="180" height="180" rx="40" fill="none" stroke="#90a7a5" stroke-width="1.2" opacity="0.08"/>
  </svg>

  <canvas id="hrv-bg" aria-hidden="true"></canvas>

  <div class="center-content">
    <!-- Cada letra en span para opacidad individual -->
    <h1 class="brand">
      <span class="solid">A</span><span>L</span><span>F</span><span>O</span><span>N</span><span>S</span><span>O</span>&nbsp;
      <span class="solid">N</span><span>A</span><span>V</span><span>A</span><span>R</span><span>R</span><span>O</span>
    </h1>

    <h2>Clinician-built AI for autonomic monitoring<br/>and post-infectious fatigue research.</h2>
    <p class="tagline">Physics + 10 years clinical practice + AI systems —<br/>the combination that makes the difference in clinical contexts where AI alone fails.</p>

    <div class="avail-block">
      <div class="badge-avail">
        <span class="badge-dot-avail"></span>· Open to remote collaboration ·
      </div>
      <p class="avail-services">Clinical AI consulting · AI model evaluation · Wearable data pipelines</p>
      <div class="avail-links">
        <a href="mailto:alfon.atman@gmail.com" class="avail-link">Contact →</a>
        <a href="https://www.linkedin.com/in/navarro-kinetica-ai" target="_blank" class="avail-link">LinkedIn →</a>
      </div>
    </div>

    <div class="scroll-cue">
      <span class="scroll-line"></span>
    </div>

    <p class="landing-context">
      Osteopath · Physics · Clinical AI · Remote worldwide
    </p>
  </div>
</section>

<!-- Tipografía Poppins ligera -->
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300&display=swap');
</style>

<script>
const canvas = document.getElementById('hrv-bg');
if (canvas) {
  const ctx = canvas.getContext('2d');
  let t = 0;
  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    // 3 líneas HRV a distintas opacidades
    [[0.06, 0.38], [0.035, 0.52], [0.02, 0.65]].forEach(([opacity, yRatio]) => {
      const yBase = canvas.height * yRatio;
      ctx.beginPath();
      ctx.strokeStyle = `rgba(144,167,165,${opacity})`;
      ctx.lineWidth = 1.2;
      for (let x = 0; x <= canvas.width; x += 3) {
        const beat = Math.exp(-Math.pow((x % 140 - 70), 2) / 100) * 35;
        const wave = Math.sin(x * 0.012 + t) * 12;
        const y = yBase - beat - wave;
        x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();
    });
    // Línea de scan suave
    const scanX = (t * 55) % (canvas.width + 160) - 80;
    const grad = ctx.createLinearGradient(scanX - 60, 0, scanX + 20, 0);
    grad.addColorStop(0, 'rgba(144,167,165,0)');
    grad.addColorStop(0.7, 'rgba(144,167,165,0.08)');
    grad.addColorStop(1, 'rgba(144,167,165,0)');
    ctx.fillStyle = grad;
    ctx.fillRect(scanX - 60, 0, 80, canvas.height);
    t += 0.007;
    requestAnimationFrame(draw);
  }
  resize();
  draw();
  window.addEventListener('resize', resize);
}
</script>

<style>
.landing-minimal {
  min-height: 92vh;
  width: 100vw;
  background: var(--main-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.background-geo {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 0;
  width: 100vw;
  height: 60vh;
  pointer-events: none;
}
#hrv-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}
.center-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100vw;
}

/* === TITULAR POR LETRA === */
.brand {
  font-family: 'Poppins', sans-serif;
  font-weight: 300;
  font-size: 3.2rem;
  letter-spacing: 0.13em;
  margin-bottom: 1.2rem;
  line-height: 1.05;
  display: inline-flex;
  flex-wrap: wrap;
  justify-content: center;
}
.brand span {
  color: var(--text-color);
  opacity: 0.28;                /* tenue por defecto */
  transition: opacity 0.3s ease;
}
.brand span.solid { opacity: 1; }/* letras destacadas */
.brand span:hover { opacity: 0.6; }

/* Subtítulo */
.center-content h2 {
  font-size: 1.35rem;
  font-weight: 500;
  color: var(--muted-text);
  letter-spacing: 0.18em;
  margin-bottom: 1.4rem;
  text-align: center;
}

/* Tagline */
.tagline {
  font-size: 0.98rem;
  font-style: italic;
  color: var(--muted-text);
  letter-spacing: 0.03em;
  opacity: 0.72;
  margin-bottom: 1rem;
  text-align: center;
  max-width: 560px;
  padding: 0 1rem;
  line-height: 1.6;
}

.scroll-cue {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.scroll-line {
  width: 1px;
  height: 48px;
  background: linear-gradient(
    to bottom,
    rgba(144,167,165,0.6),
    rgba(144,167,165,0)
  );
  animation: scroll-pulse 2s ease-in-out infinite;
}
@keyframes scroll-pulse {
  0%   { transform: scaleY(0); transform-origin: top; opacity: 0; }
  40%  { transform: scaleY(1); transform-origin: top; opacity: 1; }
  60%  { transform: scaleY(1); transform-origin: bottom; opacity: 1; }
  100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
}

.landing-context {
  margin-top: 1.5rem;
  font-size: 0.72rem;
  letter-spacing: 0.18em;
  color: var(--accent-color);
  text-transform: uppercase;
  opacity: 0.65;
}

.avail-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  margin-top: 1.6rem;
  margin-bottom: 0.5rem;
}
.badge-avail {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.35rem 1rem;
  border-radius: 2rem;
  border: 1px solid rgba(144,167,165,0.35);
  background: rgba(144,167,165,0.07);
  color: #4a8a78;
}
.badge-dot-avail {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #4db896;
  box-shadow: 0 0 6px rgba(77,184,150,0.6);
  animation: pulse-avail 2s infinite;
  flex-shrink: 0;
}
@keyframes pulse-avail {
  0%, 100% { box-shadow: 0 0 4px rgba(77,184,150,0.6); }
  50%       { box-shadow: 0 0 10px rgba(77,184,150,0.9); }
}
.avail-services {
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  color: var(--muted-text);
  opacity: 0.75;
  text-align: center;
}
.avail-links {
  display: flex;
  gap: 1.2rem;
}
.avail-link {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  color: var(--accent-color);
  text-decoration: none;
  text-transform: uppercase;
  opacity: 0.8;
  transition: opacity 0.2s;
}
.avail-link:hover { opacity: 1; }

/* Responsivo */
@media (max-width: 800px) {
  .background-geo { height: 40vh; }
  .brand { font-size: 2.1rem; }
  .center-content h2 { font-size: 1.01rem; }
}
</style>
