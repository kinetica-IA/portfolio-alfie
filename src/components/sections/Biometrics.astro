---
// Biometrics.astro — Module 1: Live Biometrics
// Client-side fetch of /data/polar_live.json
// Updated nightly by GitHub Action (polar-biometrics.yml)
---

<section id="biometrics" class="bio-section">

  <div class="bio-header">
    <h2>Biometrics Live</h2>
    <div class="live-pill">
      <span class="live-dot"></span>
      <span>Polar Grit X2 · nightly sync</span>
    </div>
  </div>

  <div id="bio-loading" class="bio-loading">
    <span class="spinner"></span>
  </div>

  <div id="bio-content" class="bio-content" style="display:none">

    <div class="metric-row">

      <div class="metric-card">
        <svg class="metric-icon" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
        </svg>
        <div class="metric-lbl">HRV · RMSSD</div>
        <div class="metric-val" id="m-hrv">—</div>
        <div class="metric-unit">ms · last night</div>
        <div class="metric-sub" id="m-date"></div>
      </div>

      <div class="metric-card">
        <svg class="metric-icon" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        <div class="metric-lbl">ANS Charge</div>
        <div class="metric-val" id="m-ans">—</div>
        <div class="metric-unit">/ 100 · autonomic load</div>
        <div class="metric-sub" id="m-steps"></div>
      </div>

      <div class="metric-card" id="card-frag">
        <svg class="metric-icon" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2"/>
          <path d="M12 6v6l3 3"/>
          <path d="M2 12h2M20 12h2M12 2v2M12 20v2" stroke-width="1.2" opacity="0.5"/>
        </svg>
        <div class="metric-lbl">Sleep Fragmentation</div>
        <div class="metric-val" id="m-frag">—</div>
        <div class="metric-unit">min awake · hypervigilance</div>
        <div class="metric-sub" id="m-interruptions"></div>
      </div>

    </div>

    <!-- HRV sparkline -->
    <div class="spark-card">
      <div class="spark-head">
        <span class="spark-title">Nocturnal HRV RMSSD — <span id="sp-n">198</span> days</span>
        <span class="spark-badge" id="sp-badge">ρ = +0.431 · p = .016</span>
      </div>
      <svg id="sparkline" class="spark-svg" viewBox="0 0 600 72"
           preserveAspectRatio="none" role="img" aria-label="HRV trend">
      </svg>
      <div class="spark-foot">
        <span class="leg"><span class="leg-line"></span>HRV RMSSD nightly</span>
        <span class="leg mono" id="sp-foot">ANS predicts PEM 48h ahead · AUC = 0.656 · Sensitivity 81%</span>
      </div>
    </div>

    <!-- Finding -->
    <div class="finding-card">
      <div class="finding-tag">Published finding</div>
      <div class="finding-stats">
        <span class="stat-rho" id="f-rho">ρ = +0.553</span>
        <span class="sep">·</span>
        <span class="stat" id="f-p">p = .001</span>
        <span class="sep">·</span>
        <span class="stat" id="f-auc">AUC = 0.768</span>
        <span class="sep">·</span>
        <span class="stat" id="f-sens">Sensitivity 84%</span>
      </div>
      <p class="finding-body">
        Nocturnal autonomic nervous system status predicts post-exertional malaise (PEM)
        48 hours in advance. The predictive signal lives in the ANS — not in serology,
        not in sleep scores.
        <span class="finding-meta">
          N = <span id="f-n">39</span> DSQ-PEM validated pairs
          · <span id="f-days">198</span> days longitudinal follow-up
          · updated <span id="f-date"></span>
        </span>
      </p>
      <a href="https://github.com/kinetica-IA/polar-lyme-predictor"
         target="_blank" rel="noopener" class="finding-btn">
        View predictor on GitHub →
      </a>
    </div>

    <!-- Model comparison -->
    <div class="models-card">
      <div class="models-header">
        <span class="models-title">Predictor comparison · LOO-CV · same data · same threshold</span>
        <span class="models-n">N = <span id="m-n-pairs">—</span> pairs</span>
      </div>
      <div class="models-grid">
        <div class="model-row model-header">
          <span>Model</span>
          <span>AUC</span>
          <span>Sensitivity</span>
          <span>Specificity</span>
        </div>
        <div class="model-row model-lr" id="row-lr">
          <span class="model-name">Logistic Regression</span>
          <span class="model-auc"  id="lr-auc">—</span>
          <span class="model-sens" id="lr-sens">—</span>
          <span class="model-spec" id="lr-spec">—</span>
        </div>
        <div class="model-row" id="row-rf">
          <span class="model-name">Random Forest</span>
          <span class="model-auc"  id="rf-auc">—</span>
          <span class="model-sens" id="rf-sens">—</span>
          <span class="model-spec" id="rf-spec">—</span>
        </div>
        <div class="model-row" id="row-gb">
          <span class="model-name">Gradient Boosting</span>
          <span class="model-auc"  id="gb-auc">—</span>
          <span class="model-sens" id="gb-sens">—</span>
          <span class="model-spec" id="gb-spec">—</span>
        </div>
      </div>
      <p class="models-note">
        min_samples_leaf=5 · scales automatically with N ·
        RF and GB will outperform LR as dataset grows beyond ~100 pairs
      </p>
    </div>

  </div>

  <div id="bio-error" class="bio-error" style="display:none">
    <p>Data syncing. Next nightly update via GitHub Action.</p>
  </div>

</section>


<style>
.bio-section {
  padding: 4rem 2rem 3rem;
  max-width: 860px;
  margin: 0 auto;
}
.bio-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 2.25rem;
}
.bio-header h2 { font-size: 1.75rem; margin: 0; }

.live-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.63rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.3rem 0.85rem;
  border-radius: 2rem;
  border: 1px solid rgba(144,167,165,0.3);
  background: rgba(144,167,165,0.06);
  color: var(--muted-text, #667);
}
.live-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #4db896;
  box-shadow: 0 0 6px rgba(77,184,150,0.6);
  animation: pulse-g 2s infinite;
  flex-shrink: 0;
}
@keyframes pulse-g {
  0%,100% { box-shadow: 0 0 4px rgba(77,184,150,0.6); }
  50%      { box-shadow: 0 0 10px rgba(77,184,150,0.9); }
}

.bio-loading { display:flex; justify-content:center; padding:3rem; }
.spinner {
  width:28px; height:28px;
  border: 2px solid rgba(144,167,165,0.18);
  border-top-color: #90a7a5;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── Metric cards ── */
.metric-row {
  display: flex;
  gap: 1.1rem;
  flex-wrap: wrap;
  margin-bottom: 1.25rem;
}
.metric-card {
  flex: 1;
  min-width: 145px;
  background: #fff;
  border: 1px solid rgba(144,167,165,0.18);
  border-radius: 10px;
  padding: 1.15rem 1.4rem;
  box-shadow: 0 2px 10px rgba(144,167,165,0.07);
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
}
.metric-icon {
  width:18px; height:18px;
  color:#90a7a5;
  margin-bottom:0.45rem;
  opacity:0.7;
}
.metric-lbl {
  font-size:0.62rem;
  letter-spacing:0.13em;
  text-transform:uppercase;
  color:var(--muted-text,#667);
  opacity:0.7;
}
.metric-val {
  font-family:'DM Mono','Courier New',monospace;
  font-size:2rem;
  font-weight:400;
  color:var(--text-color,#1a2a2a);
  letter-spacing:-0.02em;
  line-height:1.15;
}
.metric-unit {
  font-size:0.67rem;
  color:var(--muted-text,#667);
  opacity:0.5;
  letter-spacing:0.04em;
}
.metric-sub {
  font-size:0.67rem;
  color:var(--muted-text,#667);
  opacity:0.5;
  margin-top:0.25rem;
}

/* ── Sparkline ── */
.spark-card {
  background:#fff;
  border:1px solid rgba(144,167,165,0.18);
  border-radius:10px;
  padding:1.15rem 1.4rem;
  margin-bottom:1.2rem;
  box-shadow:0 2px 10px rgba(144,167,165,0.07);
}
.spark-head {
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:0.5rem;
  margin-bottom:0.65rem;
}
.spark-title {
  font-size:0.68rem;
  letter-spacing:0.09em;
  text-transform:uppercase;
  color:var(--muted-text,#667);
  opacity:0.7;
}
.spark-badge {
  font-family:'DM Mono','Courier New',monospace;
  font-size:0.62rem;
  color:#4a8a78;
  background:rgba(144,167,165,0.09);
  border:1px solid rgba(144,167,165,0.25);
  padding:0.18rem 0.55rem;
  border-radius:1rem;
  letter-spacing:0.05em;
}
.spark-svg {
  width:100%; height:72px;
  display:block; overflow:visible;
}
.spark-foot {
  display:flex;
  align-items:center;
  gap:1.4rem;
  flex-wrap:wrap;
  margin-top:0.55rem;
}
.leg {
  display:inline-flex;
  align-items:center;
  gap:0.4rem;
  font-size:0.63rem;
  color:var(--muted-text,#667);
  opacity:0.6;
  letter-spacing:0.04em;
}
.leg-line {
  display:inline-block;
  width:12px; height:2px;
  border-radius:1px;
  background:#90a7a5;
}
.mono { font-family:'DM Mono','Courier New',monospace; opacity:0.45; }

/* ── Finding card ── */
.finding-card {
  background:rgba(144,167,165,0.04);
  border:1px solid rgba(144,167,165,0.18);
  border-left:3px solid #90a7a5;
  border-radius:10px;
  padding:1.4rem 1.5rem;
}
.finding-tag {
  font-size:0.58rem;
  letter-spacing:0.15em;
  text-transform:uppercase;
  color:var(--accent-color,#90a7a5);
  opacity:0.75;
  margin-bottom:0.45rem;
}
.finding-stats {
  display:flex;
  align-items:baseline;
  flex-wrap:wrap;
  gap:0.4rem;
  margin-bottom:0.75rem;
}
.stat-rho {
  font-family:'DM Mono','Courier New',monospace;
  font-size:1.1rem;
  color:#4a8a78;
  font-weight:500;
}
.stat {
  font-family:'DM Mono','Courier New',monospace;
  font-size:0.95rem;
  color:var(--text-color,#1a2a2a);
}
.sep { color:var(--muted-text,#667); opacity:0.35; font-size:0.9rem; }

.finding-body {
  font-size:0.88rem;
  line-height:1.62;
  color:#445;
  margin-bottom:1rem;
}
.finding-meta {
  display:block;
  margin-top:0.4rem;
  font-size:0.78rem;
  opacity:0.55;
}
.finding-btn {
  display:inline-flex;
  align-items:center;
  gap:0.5rem;
  font-size:0.72rem;
  font-weight:500;
  letter-spacing:0.09em;
  text-transform:uppercase;
  color:var(--accent-color,#90a7a5);
  border:1px solid rgba(144,167,165,0.35);
  border-radius:6px;
  padding:0.4rem 1rem;
  text-decoration:none;
  transition:background 0.2s, border-color 0.2s;
}
.finding-btn:hover {
  background:rgba(144,167,165,0.08);
  border-color:var(--accent-color,#90a7a5);
}

.bio-error {
  text-align:center;
  padding:2rem;
  font-size:0.85rem;
  color:var(--muted-text,#667);
  opacity:0.55;
}

@media (max-width:580px) {
  .bio-header { flex-direction:column; align-items:flex-start; }
  .metric-val { font-size:1.65rem; }
  .spark-head { flex-direction:column; align-items:flex-start; }
}

/* ── Model comparison ── */
.models-card {
  background:#fff;
  border:1px solid rgba(144,167,165,0.18);
  border-radius:10px;
  padding:1.15rem 1.4rem;
  margin-top:1.2rem;
  box-shadow:0 2px 10px rgba(144,167,165,0.07);
}
.models-header {
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:0.5rem;
  margin-bottom:0.9rem;
}
.models-title {
  font-size:0.62rem;
  letter-spacing:0.11em;
  text-transform:uppercase;
  color:var(--muted-text,#667);
  opacity:0.7;
}
.models-n {
  font-family:'DM Mono','Courier New',monospace;
  font-size:0.62rem;
  color:#4a8a78;
  background:rgba(144,167,165,0.09);
  border:1px solid rgba(144,167,165,0.25);
  padding:0.18rem 0.55rem;
  border-radius:1rem;
}
.models-grid {
  display:grid;
  grid-template-columns: 1.8fr 1fr 1fr 1fr;
  gap:0.3rem 0;
}
.model-row {
  display:contents;
}
.model-row > span {
  padding:0.45rem 0.5rem;
  font-size:0.78rem;
  border-bottom:1px solid rgba(144,167,165,0.1);
}
.model-header > span {
  font-size:0.6rem;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color:var(--muted-text,#667);
  opacity:0.5;
  padding-bottom:0.35rem;
}
.model-name { color:var(--text-color,#1a2a2a); }
.model-auc  {
  font-family:'DM Mono','Courier New',monospace;
  font-weight:500;
  color:var(--text-color,#1a2a2a);
}
.model-sens, .model-spec {
  font-family:'DM Mono','Courier New',monospace;
  color:var(--muted-text,#667);
}
.model-best > span {
  background:rgba(144,167,165,0.07);
}
.model-best .model-auc { color:#4a8a78; }
.models-note {
  font-size:0.67rem;
  color:var(--muted-text,#667);
  opacity:0.45;
  margin-top:0.75rem;
  margin-bottom:0;
  letter-spacing:0.02em;
}
</style>


<script>
(async () => {
  const loading = document.getElementById('bio-loading');
  const content = document.getElementById('bio-content');
  const errBox  = document.getElementById('bio-error');

  try {
    const res = await fetch('/data/polar_live.json', { cache: 'no-cache' });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    const latest  = data.latest  || {};
    const series  = data.series  || [];
    const finding = data.finding || {};
    const pred    = data.predictor || {};

    // ── Helpers ───────────────────────────────────────────────────────────
    const fmt = (v, d=0) => v != null ? (+v).toFixed(d) : '—';

    /** Scan series backwards for the last entry that has `field`. */
    function lastKnown(field) {
      for (let i = series.length - 1; i >= 0; i--) {
        if (series[i][field] != null) return series[i];
      }
      return null;
    }

    /** Short "DD Mon" label for a YYYY-MM-DD string. */
    function shortDate(iso) {
      if (!iso) return '';
      const [,m,d] = iso.split('-');
      return `${+d} ${['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][+m]}`;
    }

    // ── Metrics — fall back to last known in series if latest is missing ──
    const hrv   = latest.hrv_rmssd_night ?? latest.sleep_hrv_avg_ms;
    const steps = latest.steps;
    const day   = latest.date || '';

    // ANS charge: try latest first, then series
    const ansRow  = (latest.recovery_sublevel ?? latest.ans_charge) != null
                    ? latest : (lastKnown('recovery_sublevel') ?? lastKnown('ans_charge') ?? {});
    const ans     = ansRow.recovery_sublevel ?? ansRow.ans_charge;
    const ansDate = ansRow.date !== day ? shortDate(ansRow.date) : '';

    // Sleep fragmentation: try latest first, then series
    const fragRow  = latest.sleep_wake_min != null
                     ? latest : (lastKnown('sleep_wake_min') ?? {});
    const frag     = fragRow.sleep_wake_min;
    const intr     = fragRow.sleep_interruptions;
    const fragDate = fragRow.date !== day ? shortDate(fragRow.date) : '';

    document.getElementById('m-hrv').textContent  = fmt(hrv);
    document.getElementById('m-ans').textContent  = fmt(ans);
    document.getElementById('m-frag').textContent = frag != null ? fmt(frag) : '—';
    document.getElementById('m-date').textContent = day;
    document.getElementById('m-steps').textContent =
      steps != null ? `${(+steps).toLocaleString('en-GB')} steps`
                    : ansDate ? `last known ${ansDate}` : '';
    document.getElementById('m-interruptions').textContent =
      intr != null
        ? `${intr} interruptions${fragDate ? ' · ' + fragDate : ''}`
        : fragDate ? `as of ${fragDate}` : '';

    // Finding metadata — pull live from JSON
    const nDays  = series.length || finding.n_days || 198;
    const nPairs = pred.n_training || finding.n_pairs || finding.n_diary || 39;
    document.getElementById('sp-n').textContent   = nDays;
    document.getElementById('f-n').textContent    = nPairs;
    document.getElementById('f-days').textContent = nDays;
    document.getElementById('f-date').textContent = data.updated_at
      ? data.updated_at.slice(0,10) : '';

    // Live finding stats
    if (finding.spearman_rho != null)
      document.getElementById('f-rho').textContent =
        `ρ = ${finding.spearman_rho >= 0 ? '+' : ''}${finding.spearman_rho.toFixed(3)}`;
    if (finding.p_value != null)
      document.getElementById('f-p').textContent =
        `p = .${String(Math.round(finding.p_value * 1000)).padStart(3,'0')}`;
    if (finding.auc != null)
      document.getElementById('f-auc').textContent =
        `AUC = ${finding.auc.toFixed(3)}`;
    if (finding.sensitivity_pct != null)
      document.getElementById('f-sens').textContent =
        `Sensitivity ${Math.round(finding.sensitivity_pct)}%`;

    // ── Spark badge y foot — eliminar hardcodes ───────────────────────────
    const spBadge = document.getElementById('sp-badge');
    const spFoot  = document.getElementById('sp-foot');
    if (spBadge && finding.spearman_rho != null && finding.p_value != null) {
      const rhoStr  = `ρ = ${finding.spearman_rho >= 0 ? '+' : ''}${finding.spearman_rho.toFixed(3)}`;
      const pStr    = `p = .${String(Math.round(finding.p_value * 1000)).padStart(3,'0')}`;
      spBadge.textContent = `${rhoStr} · ${pStr}`;
    }
    if (spFoot && finding.auc != null && finding.sensitivity_pct != null) {
      spFoot.textContent =
        `ANS predicts PEM 48h ahead · AUC = ${finding.auc.toFixed(3)} · Sensitivity ${Math.round(finding.sensitivity_pct)}%`;
    }

    // ── Model comparison table ────────────────────────────────────────────
    const models = pred.models || {};
    const fmtPct = v => v != null ? `${Math.round(v * 100)}%` : '—';
    const fmtAuc = v => v != null ? v.toFixed(3) : '—';

    const mNPairs = document.getElementById('m-n-pairs');
    if (mNPairs) mNPairs.textContent = pred.n_training || '—';

    const modelMap = {
      lr: models.logistic_regression || {},
      rf: models.random_forest       || {},
      gb: models.gradient_boosting   || {},
    };
    for (const [key, m] of Object.entries(modelMap)) {
      const auc  = document.getElementById(`${key}-auc`);
      const sens = document.getElementById(`${key}-sens`);
      const spec = document.getElementById(`${key}-spec`);
      if (auc)  auc.textContent  = fmtAuc(m.auc);
      if (sens) sens.textContent = fmtPct(m.sensitivity);
      if (spec) spec.textContent = fmtPct(m.specificity);
    }

    // Highlight best AUC row
    const aucs = [
      { id: 'row-lr', v: modelMap.lr.auc },
      { id: 'row-rf', v: modelMap.rf.auc },
      { id: 'row-gb', v: modelMap.gb.auc },
    ].filter(r => r.v != null);
    if (aucs.length) {
      const best = aucs.reduce((a,b) => a.v > b.v ? a : b);
      const bestRow = document.getElementById(best.id);
      if (bestRow) bestRow.classList.add('model-best');
    }

    // ── Sparkline ─────────────────────────────────────────────────────────
    const svg = document.getElementById('sparkline');
    const W = 600, H = 72, pad = 5;
    const ns  = 'http://www.w3.org/2000/svg';

    const base = document.createElementNS(ns,'line');
    ['x1','y1','x2','y2'].forEach((a,i)=>base.setAttribute(a,[0,H/2,W,H/2][i]));
    base.setAttribute('stroke','#90a7a5');
    base.setAttribute('stroke-width','0.4');
    base.setAttribute('opacity','0.25');
    svg.appendChild(base);

    const pts = series
      .map(r => ({ v: r.hrv_rmssd_night ?? r.sleep_hrv_avg_ms }))
      .filter(r => r.v != null);

    if (pts.length >= 3) {
      const vals  = pts.map(r => r.v);
      const min   = Math.min(...vals), max = Math.max(...vals);
      const range = max - min || 1;
      const toXY  = (r,i) => [
        (i / (pts.length-1)) * W,
        pad + (1-(r.v-min)/range) * (H - pad*2)
      ];
      const xy = pts.map(toXY);
      const polyStr = xy.map(([x,y])=>`${x.toFixed(1)},${y.toFixed(1)}`).join(' ');

      // gradient fill
      const defs = document.createElementNS(ns,'defs');
      const grad = document.createElementNS(ns,'linearGradient');
      grad.setAttribute('id','hrv-fill');
      grad.setAttribute('x1','0'); grad.setAttribute('y1','0');
      grad.setAttribute('x2','0'); grad.setAttribute('y2','1');
      [['0%','0.15'],['100%','0']].forEach(([off,op])=>{
        const s = document.createElementNS(ns,'stop');
        s.setAttribute('offset',off);
        s.setAttribute('stop-color','#90a7a5');
        s.setAttribute('stop-opacity',op);
        grad.appendChild(s);
      });
      defs.appendChild(grad);
      svg.insertBefore(defs, svg.firstChild);

      const [fx] = xy[0], [lx] = xy[xy.length-1];
      const fill = document.createElementNS(ns,'polygon');
      fill.setAttribute('points', `${fx.toFixed(1)},${H} ${polyStr} ${lx.toFixed(1)},${H}`);
      fill.setAttribute('fill','url(#hrv-fill)');
      svg.appendChild(fill);

      const line = document.createElementNS(ns,'polyline');
      line.setAttribute('points', polyStr);
      line.setAttribute('fill','none');
      line.setAttribute('stroke','#90a7a5');
      line.setAttribute('stroke-width','1.4');
      line.setAttribute('stroke-linejoin','round');
      svg.appendChild(line);

      // latest dot
      const [dx,dy] = xy[xy.length-1];
      const dot = document.createElementNS(ns,'circle');
      dot.setAttribute('cx',dx.toFixed(1));
      dot.setAttribute('cy',dy.toFixed(1));
      dot.setAttribute('r','3.5');
      dot.setAttribute('fill','#90a7a5');
      svg.appendChild(dot);

      // draw animation
      line.style.strokeDasharray  = String(W*2);
      line.style.strokeDashoffset = String(W*2);
      line.style.transition = 'stroke-dashoffset 1.8s ease-out';
      requestAnimationFrame(()=>{ line.style.strokeDashoffset = '0'; });
    }

    loading.style.display = 'none';
    content.style.display = '';

  } catch(e) {
    console.warn('[Biometrics]', e);
    loading.style.display = 'none';
    errBox.style.display  = '';
  }
})();
</script>
