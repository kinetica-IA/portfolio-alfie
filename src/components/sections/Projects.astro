---
---
<section id="projects" class="projects-section">
  <h2>Projects</h2>
  <div class="project-list">

    <article class="project-card featured reveal" data-delay="0">
      <svg class="ecg-mini" viewBox="0 0 200 36"
           width="110" height="22" aria-hidden="true">
        <polyline
          points="0,18 18,18 26,4 34,32 42,18 70,18 78,7 86,29 94,18 122,18 130,4 138,32 146,18 174,18 182,7 190,29 200,18"
          fill="none" stroke="#90a7a5" stroke-width="1.4"
          stroke-dasharray="400" stroke-dashoffset="400">
          <animate attributeName="stroke-dashoffset"
                   from="400" to="-400" dur="3s"
                   repeatCount="indefinite"/>
        </polyline>
      </svg>
      <div class="badge badge-published">
        <span class="badge-dot"></span>Published · Public repo · N=1 · Reproducible
      </div>
      <h3>ANS-Based Symptom Prediction in Post-Lyme Fatigue</h3>
      <p class="project-sub">N=1 Longitudinal Study · Consumer Wearable + AI Pipeline</p>
      <p>48-hour prediction of post-exertional malaise using nocturnal ANS wearable data. The dominant signal is autonomic charge lag-2 (ρ=+0.55, p&lt;0.001) combined with sleep fragmentation. Model v2 retrains automatically on every diary entry. Pipeline, dataset and methodology fully public.</p>

      <!-- Live model metrics — loaded from /data/polar_live.json -->
      <div class="proj-metrics" id="proj-metrics">
        <div class="proj-metric">
          <span class="proj-metric-val" id="pm-auc">—</span>
          <span class="proj-metric-lbl">AUC</span>
        </div>
        <div class="proj-metric">
          <span class="proj-metric-val" id="pm-sens">—</span>
          <span class="proj-metric-lbl">Sensitivity</span>
        </div>
        <div class="proj-metric">
          <span class="proj-metric-val" id="pm-spec">—</span>
          <span class="proj-metric-lbl">Specificity</span>
        </div>
        <div class="proj-metric">
          <span class="proj-metric-val" id="pm-n">—</span>
          <span class="proj-metric-lbl">N pairs</span>
        </div>
      </div>

      <p class="stack"><em>Python · scikit-learn · LangGraph · Polar Grit X2 · ChromaDB</em></p>
      <a href="https://github.com/kinetica-IA/polar-lyme-predictor" target="_blank" class="project-btn">View on GitHub →</a>
    </article>

    <article class="project-card reveal" data-delay="120">
      <!-- scatter / residual icon -->
      <svg class="residual-plot" viewBox="0 0 110 36"
           width="110" height="36" aria-hidden="true">
        <!-- axes -->
        <line x1="12" y1="28" x2="100" y2="28" stroke="#90a7a5" stroke-width="0.8" opacity="0.4"/>
        <line x1="12" y1="4"  x2="12"  y2="28" stroke="#90a7a5" stroke-width="0.8" opacity="0.4"/>
        <!-- trend line -->
        <line x1="16" y1="26" x2="96" y2="8" stroke="#c4855a" stroke-width="1"
              stroke-dasharray="3,2" opacity="0.6"/>
        <!-- scatter dots -->
        <circle cx="22" cy="24" r="2" fill="#90a7a5" opacity="0.7"/>
        <circle cx="34" cy="20" r="2" fill="#90a7a5" opacity="0.7"/>
        <circle cx="44" cy="18" r="2.5" fill="#c4855a" opacity="0.85"/>
        <circle cx="54" cy="15" r="2" fill="#90a7a5" opacity="0.7"/>
        <circle cx="64" cy="13" r="2" fill="#90a7a5" opacity="0.7"/>
        <circle cx="74" cy="10" r="2.5" fill="#c4855a" opacity="0.85"/>
        <circle cx="84" cy="9"  r="2" fill="#90a7a5" opacity="0.7"/>
        <circle cx="92" cy="7"  r="2" fill="#90a7a5" opacity="0.7"/>
      </svg>
      <div class="badge badge-research">
        <span class="badge-dot"></span>research / cognitive phenotyping
      </div>
      <h3>Residual Patterns as Clinical Signal</h3>
      <p class="project-sub">N=1 Longitudinal · Residual Analysis · Cognitive Phenotyping</p>
      <p>Most models treat prediction error as noise. This project inverts that assumption: in neurological Lyme disease, the residuals of an ANS-based severity predictor correlate strongly with brain fog (ρ=+0.663, p&lt;0.0001) and autonomic dysfunction (ρ=+0.393, p=0.043) — symptoms the patient often cannot articulate. The model's failure is the finding. Built on 34 days of longitudinal Polar Grit X2 data and a 7-domain clinical diary.</p>
      <div class="tag-row">
        <span class="tag">methodology</span>
        <span class="tag">Lyme</span>
        <span class="tag">cognitive phenotyping</span>
        <span class="tag">residual analysis</span>
      </div>
      <p class="stack"><em>Python · scipy · scikit-learn · Polar Grit X2</em></p>
    </article>

    <article class="project-card reveal" data-delay="240">
      <svg class="node-graph" viewBox="0 0 120 36"
           width="110" height="30" aria-hidden="true">
        <circle cx="20" cy="18" r="4" fill="none"
                stroke="#90a7a5" stroke-width="1.2"/>
        <circle cx="60" cy="18" r="4" fill="none"
                stroke="#90a7a5" stroke-width="1.2"/>
        <circle cx="100" cy="18" r="4" fill="none"
                stroke="#90a7a5" stroke-width="1.2"/>
        <line x1="24" y1="18" x2="56" y2="18"
              stroke="#90a7a5" stroke-width="1"
              stroke-dasharray="4,3" opacity="0.5"/>
        <line x1="64" y1="18" x2="96" y2="18"
              stroke="#90a7a5" stroke-width="1"
              stroke-dasharray="4,3" opacity="0.5"/>
        <text x="20" y="30" text-anchor="middle"
              font-size="5" fill="#90a7a5" opacity="0.6"
              font-family="monospace">dispatch</text>
        <text x="60" y="30" text-anchor="middle"
              font-size="5" fill="#90a7a5" opacity="0.6"
              font-family="monospace">respond</text>
        <text x="100" y="30" text-anchor="middle"
              font-size="5" fill="#90a7a5" opacity="0.6"
              font-family="monospace">alma</text>
        <circle cx="20" cy="18" r="4" fill="rgba(144,167,165,0.15)">
          <animate attributeName="r" values="4;8;4"
                   dur="2.5s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values="0.4;0;0.4"
                   dur="2.5s" repeatCount="indefinite"/>
        </circle>
      </svg>
      <div class="badge badge-progress">
        <span class="badge-dot"></span>In progress · Architecture public
      </div>
      <h3>IO · Local-First Clinical AI Agent</h3>
      <p class="project-sub">Context Engine · LangGraph · ALMA Framework</p>
      <p>IO began as a monolithic agent (io_agent.py, 2400 lines) with keyword routing and Ollama for local inference. It now runs as a deterministic 7-node LangGraph graph on branch phase1/react-graph (commit 835b892). The core architectural shift: Ollama eliminated, Anthropic Claude as sole LLM provider, and a dedicated Context Engine (L0) that enriches every prompt with personal RAG + clinical rules before any LLM call. The model is interchangeable. IO is not.<br><br>Key metrics: 20-tool registry · 3 autonomous loops · ALMA ethical gate with LoRA pair logging · Connector pipeline verified end-to-end (GitHub API + portfolio git push + LinkedIn draft, 2026-03-16).</p>
      <p class="stack"><em>LangGraph · Anthropic Claude · ChromaDB · Python 3.13 · FastAPI · sentence-transformers · uv</em></p>
      <a href="https://github.com/kinetica-IA/polar-lyme-predictor"
         target="_blank" class="project-btn">
        See clinical use case →
      </a>
      <a href="/io-architecture.html" class="project-btn" style="margin-left:0.5rem">
        Explore architecture →
      </a>
    </article>

  </div>
</section>

<style>
  .projects-section {
    padding: 4rem 2rem;
  }

  .projects-section h2 {
    text-align: center;
    font-size: 1.75rem;
    margin-bottom: 2.5rem;
  }

  .project-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }

  .project-card {
    background: #ffffff;
    border: 1px solid rgba(144,167,165,0.18);
    border-radius: 12px;
    padding: 2rem;
    width: 320px;
    box-shadow: 0 2px 16px rgba(144,167,165,0.08),
                0 1px 3px rgba(0,0,0,0.04);
    transition: transform 0.3s ease,
                box-shadow 0.3s ease,
                border-color 0.3s ease;
    text-align: left;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(144,167,165,0.15),
                0 2px 8px rgba(0,0,0,0.06);
    border-color: rgba(144,167,165,0.4);
  }

  .project-card.featured {
    border-left: 3px solid #90a7a5;
  }

  .ecg-mini {
    display: block;
    margin-bottom: 0.75rem;
    opacity: 0.7;
  }

  .node-graph {
    display: block;
    margin-bottom: 0.75rem;
    opacity: 0.8;
  }

  /* Badge system */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding: 0.35rem 0.85rem;
    border-radius: 2rem;
    margin-bottom: 1rem;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .badge-published {
    background: rgba(144,167,165,0.1);
    color: #4a8a78;
    border: 1px solid rgba(144,167,165,0.3);
  }
  .badge-published .badge-dot {
    background: #4db896;
    box-shadow: 0 0 6px rgba(77,184,150,0.6);
    animation: pulse-green 2s infinite;
  }
  .badge-progress {
    background: rgba(196,133,90,0.08);
    color: #a06040;
    border: 1px solid rgba(196,133,90,0.25);
  }
  .badge-progress .badge-dot { background: var(--organic-warm); }
  .badge-research {
    background: rgba(196,133,90,0.07);
    color: #a06040;
    border: 1px solid rgba(196,133,90,0.2);
  }
  .badge-research .badge-dot { background: #c4855a; }

  .residual-plot {
    display: block;
    margin-bottom: 0.75rem;
    opacity: 0.85;
  }

  /* Tag pills */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0.75rem 0 0.5rem;
  }
  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: #90a7a5;
    background: rgba(144,167,165,0.08);
    border: 1px solid rgba(144,167,165,0.22);
    border-radius: 3px;
    padding: 0.2rem 0.55rem;
  }

  @keyframes pulse-green {
    0%, 100% { box-shadow: 0 0 4px rgba(77,184,150,0.6); }
    50% { box-shadow: 0 0 10px rgba(77,184,150,0.9); }
  }

  .project-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
    line-height: 1.35;
  }

  .project-sub {
    font-size: 0.82rem;
    color: var(--muted-text);
    margin-bottom: 0.8rem;
    font-style: italic;
  }

  .project-card p {
    font-size: 0.92rem;
    line-height: 1.55;
    margin-bottom: 0.8rem;
    color: #445;
  }

  .stack {
    font-size: 0.8rem !important;
    color: #778 !important;
  }

  .project-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 1rem;
    border-radius: 8px;
  }

  .project-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.55rem 1.2rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--accent-color);
    border: 1px solid rgba(144,167,165,0.35);
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.25s ease,
                border-color 0.25s ease,
                gap 0.25s ease;
  }

  .project-btn:hover {
    background: rgba(144,167,165,0.08);
    border-color: var(--accent-color);
    gap: 0.75rem;
    text-decoration: none;
  }

  /* Live model metrics block */
  .proj-metrics {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin: 1rem 0 0.75rem;
    padding: 0.75rem 1rem;
    background: rgba(144,167,165,0.06);
    border: 1px solid rgba(144,167,165,0.18);
    border-radius: 8px;
  }
  .proj-metric {
    flex: 1;
    min-width: 52px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }
  .proj-metric-val {
    font-size: 1.05rem;
    font-weight: 600;
    color: #3a7a6a;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.01em;
  }
  .proj-metric-lbl {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #889;
  }
</style>

<script>
  (async () => {
    try {
      const r = await fetch('/data/polar_live.json');
      if (!r.ok) return;
      const d = await r.json();
      const p = d.predictor ?? {};

      const fmt = (v, dec) => v != null ? (+v).toFixed(dec) : '—';

      const auc  = document.getElementById('pm-auc');
      const sens = document.getElementById('pm-sens');
      const spec = document.getElementById('pm-spec');
      const n    = document.getElementById('pm-n');

      if (auc)  auc.textContent  = fmt(p.auc, 3);
      if (sens) sens.textContent = p.sensitivity != null
        ? (p.sensitivity * 100).toFixed(1) + '%' : '—';
      if (spec) spec.textContent = p.specificity != null
        ? (p.specificity * 100).toFixed(1) + '%' : '—';
      if (n)    n.textContent    = p.n_training ?? '—';
    } catch (e) {
      // silently fail — fallback shows "—"
    }
  })();
</script>
