---
// src/layouts/Layout.astro
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#f0f9f9" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- SEO -->
    <title>Kinetica AI — Clinical AI Systems</title>
    <meta name="description" content="Clinical AI systems built where data meets the patient. Multi-symptom prediction from wearable autonomic data. Built by a clinician." />
    <meta name="author" content="Alfonso Navarro" />
    <meta name="keywords" content="Clinical AI, Kinetica AI, HRV, autonomic nervous system, post-Lyme, wearable monitoring, healthtech, Nordic" />
    <link rel="canonical" href="https://www.kineticaai.com" />

    <!-- Open Graph -->
    <meta property="og:title" content="Kinetica AI — Clinical AI Systems" />
    <meta property="og:description" content="Clinical AI systems built where data meets the patient." />
    <meta property="og:image" content="https://www.kineticaai.com/og-image.jpg" />
    <meta property="og:url" content="https://www.kineticaai.com" />
    <meta property="og:type" content="website" />

    <!-- Schema.org -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "Kinetica AI",
          "url": "https://www.kineticaai.com",
          "description": "Clinical AI systems for wearable autonomic monitoring and multi-symptom prediction.",
          "founder": {
            "@type": "Person",
            "@id": "#alfonso-navarro"
          },
          "sameAs": [
            "https://www.linkedin.com/in/navarro-kinetica-ai",
            "https://github.com/kinetica-IA"
          ]
        },
        {
          "@type": "Person",
          "@id": "#alfonso-navarro",
          "name": "Alfonso Navarro",
          "jobTitle": "Clinical AI Builder & Osteopath",
          "url": "https://www.kineticaai.com",
          "sameAs": [
            "https://www.linkedin.com/in/navarro-kinetica-ai",
            "https://github.com/kinetica-IA"
          ],
          "knowsAbout": ["Clinical AI", "Heart Rate Variability", "Autonomic Nervous System", "Osteopathy", "Biomechanics"]
        },
        {
          "@type": "SoftwareApplication",
          "name": "polar-lyme-predictor",
          "url": "https://github.com/kinetica-IA/polar-lyme-predictor",
          "applicationCategory": "HealthApplication",
          "description": "Multi-symptom clinical prediction from wearable HRV data. Open-source, N-of-1 longitudinal design.",
          "operatingSystem": "Cross-platform",
          "author": { "@type": "Person", "@id": "#alfonso-navarro" }
        },
        {
          "@type": "Dataset",
          "name": "Kinetica Biometric Archive",
          "description": "200+ nights of RR interval data, daily symptom diary, and processed HRV features from a single post-Lyme patient.",
          "url": "https://github.com/kinetica-IA/polar-lyme-predictor",
          "license": "https://opensource.org/licenses/MIT",
          "creator": { "@type": "Person", "@id": "#alfonso-navarro" },
          "temporalCoverage": "2024/2026",
          "variableMeasured": ["Heart Rate Variability", "RMSSD", "Sleep Score", "Symptom Severity"]
        }
      ]
    }
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
