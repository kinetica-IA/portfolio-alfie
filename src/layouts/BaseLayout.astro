---
import '../styles/global.css';
---
<html lang="en">
  <head>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <meta name="theme-color" content="#0a0a0a">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Alfonso Navarro",
    "alternateName": "Kinetica AI",
    "url": "https://www.kineticaai.com",
    "image": "https://www.kineticaai.com/og-image.jpg",
    "sameAs": [
      "https://www.linkedin.com/in/navarro-kinetica-ai",
      "https://github.com/kinetica-IA"
    ],
    "jobTitle": "Osteopath & Clinical AI Builder"
  }
  </script>    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Meta SEO Básico -->
    <meta name="title" content="Alfonso Navarro – Kinetica AI">
    <meta name="description" content="Osteopath and Clinical AI Builder with 10+ years of clinical practice. Building AI systems for autonomic monitoring, wearable data pipelines, and post-infectious fatigue research. Remote collaboration worldwide.">
    <meta name="author" content="Alfonso Navarro Arredondo">
    <meta name="keywords" content="Clinical AI, Alfonso Navarro, Kinetica AI, osteopath, biomechanics, HRV, autonomic nervous system, post-Lyme fatigue, post-infectious fatigue, wearable monitoring, AI agent, LangGraph, healthtech, AI model evaluation, Anthropic, Outlier, Norway, Nordic healthtech">
    <meta name="robots" content="index, follow">
    <meta name="language" content="en">
    <meta name="revisit-after" content="7 days">
    <meta name="distribution" content="global">

    <!-- Meta preview image -->
    <meta property="og:title" content="Alfonso Navarro – Kinetica AI">
    <meta property="og:description" content="Osteopath and Clinical AI Builder. AI systems for autonomic monitoring and post-infectious fatigue research. 10+ years clinical practice meets machine learning.">
    <meta property="og:image" content="https://www.kineticaai.com/og-image.jpg">
    <meta property="og:url" content="https://www.kineticaai.com">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Alfonso Navarro – Kinetica AI">
    <meta name="twitter:description" content="Osteopath and Clinical AI Builder. ANS-based symptom prediction, local AI agents, post-infectious fatigue research.">

    <title>{Astro.props.title || 'Alfonso Navarro – Kinetica AI'}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,600,700,800&display=swap" rel="stylesheet">
<link rel="manifest" href="/manifest.webmanifest">
  </head>
  <body aria-label="Portfolio of Alfonso Navarro – Kinetica AI">
    <header>
      <slot name="header" />
    </header>
    <main class="main-wrapper">
      <slot />
    </main>
    <footer>
      <slot name="footer" />
    </footer>
    <script>
      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const delay = Number(e.target.dataset.delay) || 0;
            setTimeout(() => e.target.classList.add('visible'), delay);
          }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((el, i) => {
        if (!el.dataset.delay) el.dataset.delay = String(i * 80);
        obs.observe(el);
      });
    </script>
  </body>
</html>

<style>
  .main-wrapper {
    padding-left: 3rem;
    padding-right: 3rem;
    max-width: 1080px;
    margin: 0 auto;
  }

  @media(min-width: 1024px) {
    .main-wrapper {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }
</style>
